generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Ticket {
  id             String   @id @default(cuid())
  title          String
  category       String
  priority       String
  status         String
  assignedPerson String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
