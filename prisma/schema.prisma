generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ticket {
  id             String   @id @default(cuid())
  title          String
  category       String
  priority       String
  status         String
  assignedPerson String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
